{
  "name": "CategoriaFinanceira",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string",
      "description": "Nome da categoria financeira"
    },
    "tipo": {
      "type": "string",
      "enum": [
        "Receita",
        "Despesa"
      ],
      "description": "Tipo de categoria"
    },
    "ativa": {
      "type": "boolean",
      "default": true,
      "description": "Status da categoria"
    }
  },
  "required": [
    "nome",
    "tipo"
  ]
}