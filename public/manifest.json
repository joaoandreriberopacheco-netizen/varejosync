{
  "name": "P38 | ERP",
  "short_name": "P38 ERP",
  "description": "Sistema ERP P38 — gestão integrada.",
  "id": "/",
  "scope": "/",
  "start_url": "/",
  "display_override": ["standalone", "minimal-ui", "browser"],
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#ffffff",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "/brand/p38-icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    }
  ],
  "share_target": {
    "action": "/AnexoCompartilhado",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["application/pdf", "image/*", "application/*", "text/*", "*/*"]
        }
      ]
    }
  }
}
