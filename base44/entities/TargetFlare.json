{
  "name": "TargetFlare",
  "type": "object",
  "properties": {
    "status": {
      "type": "string",
      "enum": ["pending", "resolved"],
      "description": "Estado do alvo de manutenção"
    },
    "file_path": {
      "type": "string",
      "description": "Caminho do ficheiro fonte (ex.: src/pages/Home.jsx)"
    },
    "line": {
      "type": "number",
      "description": "Linha JSX no ficheiro"
    },
    "column": {
      "type": "number",
      "description": "Coluna JSX no ficheiro"
    },
    "source_location_raw": {
      "type": "string",
      "description": "Valor bruto de data-source-location (filename:line:column)"
    },
    "component_name": {
      "type": "string",
      "description": "Nome derivado do ficheiro ou componente"
    },
    "briefing": {
      "type": "string",
      "description": "Descrição do bug ou melhoria"
    },
    "action_briefing": {
      "type": "string",
      "description": "Ação objetiva esperada para correção"
    },
    "context_image_url": {
      "type": "string",
      "description": "URL opcional de imagem para contexto visual"
    },
    "confidence": {
      "type": "string",
      "enum": ["high", "medium"],
      "description": "Nível de precisão do alvo para pinpoint"
    },
    "resolution_precision": {
      "type": "string",
      "enum": ["high", "medium", "unknown"],
      "description": "Precisão utilizada na resolução do alvo"
    },
    "route": {
      "type": "string",
      "description": "Rota React (pathname) quando o alvo foi criado"
    }
  },
  "required": [
    "status",
    "file_path",
    "line",
    "column",
    "source_location_raw",
    "component_name",
    "briefing",
    "action_briefing",
    "confidence"
  ]
}
