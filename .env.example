# Copie para .env.local (não commitar). No Cursor Cloud Agent, use Secrets com os mesmos nomes.

# App Base44 (produção P38 — obrigatório no Vercel para gravações funcionarem)
VITE_BASE44_APP_ID=
VITE_BASE44_BACKEND_URL=https://p38.base44.app

# Provider de dados: omitir ou "base44" no VarejoSync. Só use "supabase" no repo a29-erp.
# VITE_P38_PROVIDER=base44

# NÃO definir no Vercel do VarejoSync (desvia gravações para Supabase):
# VITE_P38_PROVIDER=supabase
# VITE_P38_BYPASS_BASE44=true

# Autenticação — use UM dos dois (API key é mais estável para scripts):
BASE44_ACCESS_TOKEN=
# BASE44_API_KEY=
